APP_ENV=local
PORT=8000
DATABASE_URL=sqlite:///./billing.db
FRONTEND_BASE_URL=http://localhost:3000
FRONTEND_ORIGINS=http://localhost:3000,https://poker-planning-pro.vercel.app,https://planning.resyst.cl

# Billing provider default for requests that do not pass an explicit provider.
# Use fake only for local/E2E tests; use stripe or paypal in deployed Railway envs.
BILLING_PROVIDER=fake
E2E_TEST_MODE=false
E2E_TEST_SECRET=change-me

# Firebase Admin / Realtime Database projection
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON_B64=
FIREBASE_DATABASE_URL=

# Stripe provider configuration on Railway
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTH=
STRIPE_PRICE_PRO_YEAR=
STRIPE_PRICE_ENTERPRISE_MONTH=
STRIPE_PRICE_ENTERPRISE_YEAR=

# PayPal provider configuration on Railway. The frontend only toggles visibility
# with NEXT_PUBLIC_PAYPAL_ENABLED; PayPal OAuth, plan IDs, confirmation, and
# webhooks are owned by this backend.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_WEBHOOK_ID=
PAYPAL_PLAN_PRO_MONTH=
PAYPAL_PLAN_PRO_YEAR=
PAYPAL_PLAN_ENTERPRISE_MONTH=
PAYPAL_PLAN_ENTERPRISE_YEAR=
